# ============================================================
# HiLearn AI Interview Prep - Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================

# --- App Settings ---
APP_NAME="HiLearn AI Interview Prep"
APP_VERSION="1.0.0"
ENVIRONMENT="development"          # development | staging | production
DEBUG=true
PORT=8000

# --- Security ---
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,https://hilearn.in"

# --- Database ---
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="hilearn_interview"

# --- ChromaDB (Vector Store for resume embeddings) ---
CHROMA_HOST="localhost"
CHROMA_PORT=8001
CHROMA_COLLECTION="hilearn_embeddings"

# --- Groq API (LLM - llama-3.3-70b) ---
# Get your key at: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.7

# --- OpenAI (Whisper - Speech to Text) ---
OPENAI_API_KEY="sk-your_openai_api_key_here"
WHISPER_MODEL="whisper-1"

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR="./uploads"

# --- Rate Limiting ---
FREE_TIER_INTERVIEWS_PER_MONTH=3
PRO_TIER_PRICE_INR=299
PREMIUM_TIER_PRICE_INR=999
   